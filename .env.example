# Copy to .env.local for local dev, and set these in Vercel → Project → Settings →
# Environment Variables for production.

# Resend API key — sign up free at https://resend.com, create an API key.
RESEND_API_KEY=

# Where lead submissions are emailed (your inbox).
LEAD_EMAIL=jim@gofflawdfw.com

# The "from" address. Until you verify a domain in Resend, leave the default below
# (it can send to your own Resend account email). After verifying bigdatadamage.com
# in Resend, change to e.g. "Big Data Damage <leads@bigdatadamage.com>".
LEAD_FROM=Big Data Damage <onboarding@resend.dev>

# YouTube Data API v3 key — powers the auto-updating featured video on /news.
# Google Cloud Console → enable "YouTube Data API v3" → create an API key.
# Free tier = 10,000 units/day; our daily check costs ~200-300.
# If left blank, the news page shows a hand-picked fallback video instead.
YOUTUBE_API_KEY=

# AI / vector search — reserved for a future semantic-search / RAG feature.
# Not used by any code yet; set the same values in Vercel for production.
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
